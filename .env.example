# ── KAFKA ──────────────────────────────────────────────────
KAFKA_BOOTSTRAP_SERVERS=localhost:9092

# ── REDDIT ─────────────────────────────────────────────────
# Reddit's public JSON API is rate-limited and 403-blocks most
# datacenter/cloud IPs, so the producer prefers the authenticated API
# (praw) when these credentials are set and falls back to public JSON
# otherwise. Create a "script" app at https://www.reddit.com/prefs/apps
# to get a client id + secret (free).
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USER_AGENT=zeitgeist/1.0 (personal sentiment pipeline)

# ── YOUTUBE DATA API ───────────────────────────────────────
# Get this at: https://console.cloud.google.com
YOUTUBE_API_KEY=your_youtube_api_key

# ── NEWS API ───────────────────────────────────────────────
# Optional — the RSS (Google News) feed runs with no key. Set this only
# to additionally pull from NewsAPI. Get a key at https://newsapi.org
NEWS_API_KEY=your_news_api_key

# ── FLINK ──────────────────────────────────────────────────
FLINK_JOBMANAGER_HOST=localhost
FLINK_JOBMANAGER_PORT=8081

# ── LLM (llama.cpp) ────────────────────────────────────────
# Start the server with ./scripts/run_llama.sh. It uses a LOCAL GGUF file and
# never downloads — it looks in ../models for a file matching the chosen model.
LLAMA_SERVER_URL=http://localhost:8080
LLAMA_MODEL=1.5b  # 1.5b -> qwen2.5-1.5b-instruct-*.gguf | 3b -> qwen2.5-3b-instruct-*.gguf
# LLAMA_MODELS_DIR=../models       # where the launcher looks for GGUF files
# LLAMA_MODEL_FILE=/path/to.gguf   # pin an exact file (overrides LLAMA_MODEL lookup)
# LLAMA_SERVER_EXE=llama-server    # override if llama-server is not in PATH
# Must match LLAMA_PARALLEL in the launcher; lower on 8 GB machines to avoid KV-cache memory pressure.
LLM_CONCURRENCY=2
# Launcher override knobs (8 GB-friendly defaults):
# LLAMA_NGL=99        # GPU layers offloaded
# LLAMA_CTX=4096      # context size
# LLAMA_PARALLEL=2    # parallel slots (multiplies KV-cache memory)

# ── DATABASE (Neon Postgres) ───────────────────────────────
# Your Neon connection string (Neon console → Connection Details).
DATABASE_URL=postgresql://USER:PASSWORD@HOST/DBNAME?sslmode=require&channel_binding=require

# ── PIPELINE SETTINGS ──────────────────────────────────────
SLIDING_WINDOW_SIZE_SECONDS=300    # 5 minute window
SLIDING_WINDOW_SLIDE_SECONDS=30    # Slide every 30 seconds
MAX_SAMPLE_TEXTS=5                 # Max texts sent to LLM per signal
POLL_INTERVAL_SECONDS=60           # How often producers poll APIs
SCORER_WORKERS=8                   # Parallel threads for sentiment scoring
